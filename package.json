{
  "name": "chunk-reading",
  "version": "0.1.0",
  "description": "직독직해 (Korean read-in-order) cue practice — a drop-in React component + framework-agnostic core, with an optional bundled Gemini backend. Extracted from Interactive Reading Coach.",
  "keywords": ["korean", "efl", "reading", "직독직해", "chunking", "tts", "react", "nextjs"],
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/smilepat/chunk-reading.git" },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" },
    "./core": { "types": "./dist/core.d.ts", "import": "./dist/core.js", "require": "./dist/core.cjs" },
    "./server": { "types": "./dist/server.d.ts", "import": "./dist/server.js", "require": "./dist/server.cjs" }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "build:lib": "tsup",
    "prepublishOnly": "tsup",
    "test": "vitest run",
    "lint": "eslint"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@google/genai": "^2.8.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
